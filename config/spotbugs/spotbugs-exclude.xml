<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter
        xmlns="https://github.com/spotbugs/filter/3.0.0"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="https://github.com/spotbugs/filter/3.0.0 https://raw.githubusercontent.com/spotbugs/spotbugs/master/spotbugs/etc/findbugsfilter.xsd">

    <!--
        Spring injects singleton collaborators (repositories, services, template
        beans, ObjectMapper, etc.) by constructor. Retaining the injected reference
        in a private final field is the intended, framework-managed design, not an
        exposure of internal representation, so EI_EXPOSE_REP2 is a false positive
        at these dependency-injection sites across the application packages.

        The exclusion is limited to EI_EXPOSE_REP2 within com.alexandergomez.wms.
        Domain entities and value objects in these packages take primitives or
        immutable types (or make defensive copies), so they do not trigger this
        pattern; all other SpotBugs checks remain at effort=Max, threshold=Low.
    -->
    <Match>
        <Bug pattern="EI_EXPOSE_REP2"/>
        <Class name="~com\.alexandergomez\.wms\..*"/>
    </Match>
</FindBugsFilter>
