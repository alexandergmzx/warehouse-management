<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter
        xmlns="https://github.com/spotbugs/filter/3.0.0"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="https://github.com/spotbugs/filter/3.0.0 https://raw.githubusercontent.com/spotbugs/spotbugs/master/spotbugs/etc/findbugsfilter.xsd">

    <!--
        Spring injects singleton collaborators (for example NamedParameterJdbcTemplate)
        by constructor. Retaining the injected reference in a private final field is the
        intended, framework-managed design, not an exposure of internal representation,
        so EI_EXPOSE_REP2 is a false positive at these dependency-injection sites.

        The exclusion is scoped to Spring stereotype classes by naming convention.
        Domain entities and value objects (which return only immutable types) are not
        matched and remain fully analysed at effort=Max, threshold=Low.
    -->
    <Match>
        <Bug pattern="EI_EXPOSE_REP2"/>
        <Class name="~.*(Repository|Service|Controller|Filter|Configuration)"/>
    </Match>
</FindBugsFilter>
